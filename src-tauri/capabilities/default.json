{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the gitwink panel + diff windows",
  "windows": ["panel", "diff"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "clipboard-manager:allow-write-text",
    "dialog:allow-open"
  ]
}
